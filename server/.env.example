# Servidor
PORT=3001
NODE_ENV=development

# Autenticação
JWT_SECRET=coloque-uma-chave-secreta-forte-aqui
JWT_EXPIRES_IN=7d

# Banco de Dados
DB_PATH=./data/database.sqlite

# Instagram Graph API
INSTAGRAM_APP_ID=seu-app-id
INSTAGRAM_APP_SECRET=seu-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/social/instagram/callback

# TikTok API
TIKTOK_CLIENT_KEY=seu-client-key
TIKTOK_CLIENT_SECRET=seu-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3001/api/social/tiktok/callback

# YouTube Data API
YOUTUBE_API_KEY=sua-api-key
YOUTUBE_CLIENT_ID=seu-client-id
YOUTUBE_CLIENT_SECRET=seu-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/social/youtube/callback

# Google Gemini AI
GEMINI_API_KEY=sua-chave-api-gemini
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation

# Agendamento
PUBLISH_CHECK_INTERVAL=*/15 * * * *
METRICS_COLLECT_INTERVAL=0 */6 * * *

# Telegram Bot
TELEGRAM_BOT_TOKEN=seu-token-do-bot
TELEGRAM_CHAT_ID=seu-chat-id
TELEGRAM_POLL_INTERVAL=5000

# E-mail (SMTP) — Para envio do diagnóstico
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
EMAIL_FROM=CachoViva <seu-email@gmail.com>

# Pesquisa Automática
RESEARCH_SCHEDULE=0 8,14 * * 1-5
RESEARCH_AUTO_APPROVE=false

# Google Analytics Data API (para o dashboard de métricas)
# 1. Crie uma service account no Google Cloud Console
# 2. Habilite a Google Analytics Data API
# 3. Adicione o e-mail da service account como "Visualizador" no GA4
GA4_PROPERTY_ID=123456789
GA4_CLIENT_EMAIL=seu-servico@projeto.iam.gserviceaccount.com
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSj...\n-----END PRIVATE KEY-----"
